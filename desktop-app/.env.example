# ─────────────────────────────────────────
# Google Calendar - Schedule Importer configuration
# ─────────────────────────────────────────

# Which calendar to add events to (use 'primary' or a full calendar ID)
CALENDAR_ID=primary
# Minutes before event to show a popup reminder (0 = disabled)
REMINDER_MINUTES=30
# Event color ID (1-11):
#   1=Lavender  2=Sage      3=Grape    4=Flamingo  5=Banana
#   6=Tangerine 7=Peacock   8=Blueberry 9=Blueberry 10=Basil 11=Tomato
EVENT_COLOR=7
# Default work location shown in calendar events
LOCATION=PP Wrocław Świdnicka
# Path to your Google OAuth credentials file
CREDENTIALS_FILE=credentials.json
# Token cache file (created automatically after first login)
TOKEN_FILE=token.json
